datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  GUARDIAN
}

enum TopicDifficulty {
  BASICO
  INTERMEDIO
  AVANZADO
}

enum TopicStatus {
  SUGERIDO
  SELECCIONADO
  DESCARTADO
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum PlanStatus {
  DRAFT
  TOPICS_SUGGESTED
  TEACHER_REVIEW
  FINALIZED
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  role            Role             @default(STUDENT)
  isActive        Boolean          @default(true)
  // Biometric face data — stored as base64 thumbnail for comparison
  facePhoto       String?
  // Comma-separated pixel descriptor vector (simplified embedding for demo)
  faceEmbedding   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  adminProfile    AdminProfile?
  teacherProfile  TeacherProfile?
  studentProfile  StudentProfile?
  guardianProfile GuardianProfile?
  attendanceRecords AttendanceRecord[]
  biometricLogs     BiometricLog[]
}

model AdminProfile {
  id        String @id @default(uuid())
  userId    String @unique
  firstName String
  lastName  String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherProfile {
  id              String                  @id @default(uuid())
  userId          String                  @unique
  firstName       String
  lastName        String
  department      String?
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses         Course[]
  topicSelections TeacherTopicSelection[]
}

model StudentProfile {
  id             String             @id @default(uuid())
  userId         String             @unique
  firstName      String
  lastName       String
  enrollmentCode String             @unique
  grade          String?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments    CourseEnrollment[]
}

model GuardianProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  firstName String
  lastName  String
  phone     String?
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherWorkflow {
  id                      String                @id @default(uuid())
  teacherId               String
  profesor                String
  asignatura              String
  curso                   String
  contexto                String
  objetivos               String[]
  planResumen             String
  planDuracionSemanas     Int
  planEtapas              String[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  abanicoDeTemas          TeacherWorkflowTopic[]

  @@index([teacherId])
}

model TeacherWorkflowTopic {
  id          String          @id @default(uuid())
  workflowId  String
  titulo      String
  descripcion String
  dificultad  TopicDifficulty
  estado      TopicStatus     @default(SUGERIDO)
  workflow    TeacherWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

// ============================================================
// COURSE PLANNING MODELS — "The Intelligence" Agent
// ============================================================

model Course {
  id             String             @id @default(uuid())
  title          String
  description    String?
  durationMonths Int
  targetLevel    Level              @default(BEGINNER)
  subject        String
  teacherId      String
  teacher        TeacherProfile     @relation(fields: [teacherId], references: [id])
  plan           CoursePlan?
  enrollments    CourseEnrollment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model CoursePlan {
  id        String     @id @default(uuid())
  courseId  String     @unique
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rawPlan   Json
  status    PlanStatus @default(DRAFT)
  weeks     PlanWeek[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PlanWeek {
  id         String   @id @default(uuid())
  planId     String
  plan       CoursePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber Int
  title      String
  objectives String[]
  topics     Topic[]
  createdAt  DateTime @default(now())
}

model Topic {
  id             String                  @id @default(uuid())
  weekId         String
  week           PlanWeek                @relation(fields: [weekId], references: [id], onDelete: Cascade)
  title          String
  description    String
  estimatedHours Float
  resources      String[]
  isSelected     Boolean                 @default(false)
  selections     TeacherTopicSelection[]
  createdAt      DateTime                @default(now())
}

model TeacherTopicSelection {
  id         String         @id @default(uuid())
  topicId    String
  topic      Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id])
  notes      String?
  selectedAt DateTime       @default(now())

  @@unique([topicId, teacherId])
}

model CourseEnrollment {
  id         String         @id @default(uuid())
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id])
  enrolledAt DateTime       @default(now())

  @@unique([courseId, studentId])
}

// ============================================================
// BIOMETRIC AND ATTENDANCE MODELS
// ============================================================

enum AttendanceStatus {
  PRESENT
  ABSENT
  TARDY
}

enum AttendanceMethod {
  BIOMETRIC
  MANUAL
}

enum BiometricLogStatus {
  SUCCESS
  UNKNOWN
  ERROR
}

model AttendanceRecord {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp  DateTime         @default(now())
  status     AttendanceStatus @default(PRESENT)
  method     AttendanceMethod @default(BIOMETRIC)
  confidence Float?
  createdAt  DateTime         @default(now())

  @@index([userId])
}

model BiometricLog {
  id            String             @id @default(uuid())
  userId        String?
  user          User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName      String?
  userCode      String?
  timestamp     DateTime           @default(now())
  confidence    Float?
  status        BiometricLogStatus @default(UNKNOWN)
  capturedImage String?
  createdAt     DateTime           @default(now())

  @@index([userId])
}

